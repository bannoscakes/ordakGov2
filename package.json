{
  "name": "ordak-go",
  "version": "0.1.0",
  "private": true,
  "description": "Shopify delivery and pickup scheduler app with recommendation engine",
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate && remix vite:build",
    "build:extensions": "npm --workspace extensions/_cart-block-src run build",
    "predeploy": "npm run build:extensions",
    "dev": "shopify app dev",
    "dev:up": "bash scripts/dev-up.sh",
    "dev:down": "bash scripts/dev-down.sh",
    "dev:logs": "bash scripts/dev-logs.sh",
    "vite:dev": "remix vite:dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "remix-serve build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "smoke:carrier": "node scripts/smoke-carrier-service.mjs",
    "latency:carrier": "node scripts/measure-carrier-latency.mjs",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite"
  },
  "type": "module",
  "engines": {
    "node": "^20.10 || >=22.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@remix-run/node": "2.16.7",
    "@remix-run/react": "2.16.7",
    "@remix-run/serve": "2.16.7",
    "@shopify/app-bridge-react": "^4.2.10",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-api": "^13.0.0",
    "@shopify/shopify-app-remix": "^4.2.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "@vercel/remix": "2.16.7",
    "isbot": "^5.1.39",
    "prisma": "^6.19.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@remix-run/dev": "2.16.7",
    "@shopify/api-codegen-preset": "^2.0.0",
    "@shopify/cli": "^3.94.3",
    "@types/eslint": "^8.56.5",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^3.0.0"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "author": "P&T Group"
}
