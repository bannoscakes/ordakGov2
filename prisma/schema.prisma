// Prisma schema for ordakGov2 Delivery & Pickup Scheduler
// Includes recommendation engine entities

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify session storage
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Core entities
model Shop {
  id                    String    @id @default(cuid())
  shopifyDomain         String    @unique
  accessToken           String
  scope                 String?

  // Carrier Service: Shopify-assigned ID returned by carrierServiceCreate.
  // Stored so APP_UNINSTALLED can call carrierServiceDelete and avoid
  // orphaning the registration. Null means "not yet registered" (e.g. mid
  // afterAuth, or Carrier Service registration failed and we'll retry).
  carrierServiceId      String?

  // Recommendation settings
  recommendationsEnabled Boolean  @default(true)
  capacityWeight        Float     @default(0.4)
  distanceWeight        Float     @default(0.3)
  routeEfficiencyWeight Float     @default(0.2)
  personalizationWeight Float     @default(0.1)
  numAlternatives       Int       @default(3)

  // Widget appearance toggles. Both default to the post-D5 cart-block
  // behavior so existing installs see no UX change until the merchant
  // opts in.
  showRecommendedBadge   Boolean   @default(false)
  showMostAvailableBadge Boolean   @default(true)

  // Set to true by the cart-block storefront when it detects visible
  // express checkout buttons (Shop Pay / Apple Pay / Buy-it-now). Drives
  // the dashboard warning Banner that points the merchant at the
  // hide-express-buttons toggle on the cart-scheduler-embed app embed.
  diagnosticsExpressButtonsVisible Boolean @default(false)

  locations             Location[]
  zones                 Zone[]
  webhookDestinations   WebhookDestination[]

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Location {
  id                String   @id @default(cuid())
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name              String
  address           String
  city              String?
  province          String?
  country           String?
  postalCode        String?

  // Coordinates for distance calculations
  latitude          Float?
  longitude         Float?

  phone             String?
  email             String?
  timezone          String   @default("UTC")

  isActive          Boolean  @default(true)
  supportsDelivery  Boolean  @default(true)
  supportsPickup    Boolean  @default(true)

  zones             Zone[]
  slots             Slot[]
  slotTemplates     SlotTemplate[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([shopId])
}

model Zone {
  id                String   @id @default(cuid())
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  locationId        String
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name              String
  type              String   // 'postcode_range', 'postcode_list', 'radius'

  // For postcode ranges/lists
  postcodes         String[] // Array of postcodes or ranges

  // Postcodes within `postcodes` (or matched by radius) that are explicitly
  // EXCLUDED from this zone. Lets the merchant cover "all of Sydney except
  // these specific postcodes" without listing every included postcode.
  excludePostcodes  String[] @default([])

  // For radius
  radiusKm          Float?

  // Per-zone delivery base price in the merchant's currency.
  // Total delivery charge at checkout = zone.basePrice + slot.priceAdjustment.
  // Defaults to 0 so existing zones remain valid post-migration; merchant
  // must edit in admin to set the real price.
  basePrice         Decimal  @default(0) @db.Decimal(10, 2)

  isActive          Boolean  @default(true)
  priority          Int      @default(0)

  // Slots scoped to this zone (delivery slots only — pickup slots leave
  // zoneId null and use locationId).
  slots             Slot[]

  // Per-day-of-week slot config. Materialized into concrete Slot rows for
  // the next N days by the slot-materializer service.
  slotTemplates     SlotTemplate[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([shopId])
  @@index([locationId])
}

model Slot {
  id                  String   @id @default(cuid())

  // Slots are always parented to a Location. Delivery slots ALSO carry a
  // zoneId so the merchant can configure different time windows / capacity /
  // pricing per zone. Pickup slots leave zoneId null because pickup has no
  // postcode-bound zone.
  locationId          String
  location            Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  zoneId              String?
  zone                Zone?    @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  date                DateTime
  timeStart           String   // "09:00"
  timeEnd             String   // "11:00"

  capacity            Int      @default(10)
  booked              Int      @default(0)

  // Optional per-slot price premium added on top of the zone base price.
  // Lets the merchant charge extra for priority windows (e.g. 9am-11am +$10).
  // Defaults to 0; the cart-block only renders the badge when > 0.
  priceAdjustment     Decimal  @default(0) @db.Decimal(10, 2)

  // Per-slot cutoff. NULL = no cutoff (slot bookable until start). Non-null =
  // minutes before slot start at which the slot stops appearing in the
  // storefront slot loader (and is rejected by the carrier-service callback
  // as a defense-in-depth backstop).
  cutoffOffsetMinutes Int?

  // Recommendation score (0.0 - 1.0)
  recommendationScore Float?

  fulfillmentType     String   // 'delivery' or 'pickup'

  isActive            Boolean  @default(true)

  orders              OrderLink[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([locationId])
  @@index([zoneId])
  @@index([date])
  @@index([recommendationScore])
}

// Per-day-of-week slot configuration. The merchant edits these in the admin
// (per-zone for delivery, per-location for pickup), and the slot-materializer
// service generates concrete Slot rows from them for the next N days.
//
// Example: a row {dayOfWeek: 1, timeStart: "09:00", timeEnd: "11:00",
// capacity: 5, fulfillmentType: "delivery"} means "every Monday, accept up
// to 5 delivery orders for the 9am-11am window".
//
// Editing a template re-materializes future Slot rows matching its
// (zoneId/locationId, fulfillmentType, dayOfWeek) tuple. Bookings are
// preserved by leaving slots with `booked > 0` untouched.
model SlotTemplate {
  id              String   @id @default(cuid())

  // Delivery templates carry zoneId; pickup templates leave it null and
  // use locationId only (mirrors the Slot model's zone/location split).
  zoneId          String?
  zone            Zone?    @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  locationId      String
  location        Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  fulfillmentType String   // 'delivery' or 'pickup'
  dayOfWeek       Int      // 0=Sunday, 1=Monday, ..., 6=Saturday (matches JS Date.getDay())

  timeStart       String   // "09:00"
  timeEnd         String   // "11:00"

  capacity        Int      @default(10)
  priceAdjustment Decimal  @default(0) @db.Decimal(10, 2)

  // Per-slot cutoff carried forward to materialized Slot rows. NULL = no
  // cutoff. See Slot.cutoffOffsetMinutes for the runtime semantics.
  cutoffOffsetMinutes Int?

  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([zoneId])
  @@index([locationId])
  @@index([dayOfWeek])
}

model OrderLink {
  id                String   @id @default(cuid())

  shopifyOrderId    String   @unique
  shopifyOrderNumber String?

  slotId            String
  slot              Slot     @relation(fields: [slotId], references: [id], onDelete: Cascade)

  fulfillmentType   String   // 'delivery' or 'pickup'

  customerEmail     String?
  customerPhone     String?

  deliveryAddress   String?
  deliveryPostcode  String?

  // Recommendation metadata
  wasRecommended    Boolean  @default(false)
  recommendationScore Float?

  status            String   @default("scheduled") // 'scheduled', 'updated', 'canceled', 'completed'

  notes             String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  eventLogs         EventLog[]

  @@index([shopifyOrderId])
  @@index([slotId])
}

model EventLog {
  id              String    @id @default(cuid())

  orderLinkId     String?
  orderLink       OrderLink? @relation(fields: [orderLinkId], references: [id], onDelete: Cascade)

  eventType       String    // 'order.scheduled', 'order.schedule_updated', 'order.schedule_canceled', 'recommendation.viewed', 'recommendation.selected'

  payload         String    @db.Text // JSON payload

  timestamp       DateTime  @default(now())

  @@index([orderLinkId])
  @@index([eventType])
  @@index([timestamp])
}

// Recommendation entities

model CustomerPreferences {
  id                String   @id @default(cuid())

  customerId        String?  // Shopify customer ID (optional)
  customerEmail     String?  // Email hash for anonymous tracking

  // Historical preferences
  preferredDays     String[] // e.g., ["Saturday", "Sunday"]
  preferredTimes    String[] // e.g., ["09:00-11:00", "14:00-16:00"]
  preferredLocationIds String[]

  // Statistics
  totalOrders       Int      @default(0)
  lastOrderDate     DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([customerId])
  @@index([customerEmail])
}

// Schema reservation only — no UI, no runtime path yet.
// Outbound webhook receivers configured by the merchant (e.g. their own
// ordak dispatch endpoint, ERP, delivery routing system) for
// order/scheduling events. The dispatcher fires on EventLog writes and
// signs each request with the destination's HMAC secret.
model WebhookDestination {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  url         String
  secret      String   // HMAC signing secret (X-Ordak-Signature: sha256=...)

  // Default false: the merchant configures the receiver on their side
  // first, then flips this on. Auto-enabling on create would let a
  // half-configured receiver miss its first batch of events.
  enabled     Boolean  @default(false)

  // Subset of EventLog.eventType values this destination subscribes to.
  // Empty array means "all events".
  eventTypes  String[]

  // Health tracking. Bumped by the dispatcher on each delivery attempt.
  // The admin surfaces lastError + consecutiveFailures so the merchant
  // can see "this receiver has been failing for 3 days" instead of
  // discovering it only when their downstream pipeline is empty.
  lastSuccessAt        DateTime?
  lastFailureAt        DateTime?
  lastError            String?
  consecutiveFailures  Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId])
}

model RecommendationLog {
  id                  String   @id @default(cuid())

  sessionId           String
  customerId          String?
  customerEmail       String?

  shopifyDomain       String

  // What was recommended
  recommendedSlotIds  String[]
  recommendedLocationIds String[]

  // What was selected
  selectedSlotId      String?
  selectedLocationId  String?

  wasRecommended      Boolean  @default(false)

  // For analytics
  alternativesShown   String[]

  viewedAt            DateTime @default(now())
  selectedAt          DateTime?

  @@index([sessionId])
  @@index([customerId])
  @@index([shopifyDomain])
  @@index([viewedAt])
}
